generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AUDITOR
  MANAGER
  EMPLOYEE
}

enum AuditType {
  INTERNAL
  EXTERNAL
  SECURITY
  VENDOR
}

enum AuditStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ActionStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING_REVIEW
  CLOSED
}

enum RiskLikelihood {
  RARE
  UNLIKELY
  POSSIBLE
  LIKELY
  ALMOST_CERTAIN
}

enum RiskImpact {
  INSIGNIFICANT
  MINOR
  MODERATE
  MAJOR
  CATASTROPHIC
}

enum RiskStatus {
  OPEN
  MITIGATED
  ACCEPTED
  CLOSED
}

enum Framework {
  ISO_27001
  ISO_9001
  SOC_2
  GDPR
}

enum NotificationType {
  AUDIT_ASSIGNED
  FINDING_CREATED
  ACTION_OVERDUE
  DEADLINE_APPROACHING
  ORG_APPROVED
  ORG_REJECTED
  USER_INVITED
}

enum ThemeMode {
  LIGHT
  DARK
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  status      OrgStatus @default(PENDING)
  plan        String    @default("free")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  approvedAt  DateTime?
  suspendedAt DateTime?

  users              User[]
  audits             Audit[]
  findings           Finding[]
  actions            CorrectiveAction[]
  evidence           Evidence[]
  risks              Risk[]
  controls           Control[]
  controlMappings    ControlMapping[]
  notifications      Notification[]
  activityLogs       ActivityLog[]
  settings           OrgSettings?
  invites            OrgInvite[]
  enabledFrameworks  OrgFramework[]

  @@index([status])
  @@index([slug])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  supabaseId     String    @unique
  email          String
  name           String?
  role           UserRole  @default(EMPLOYEE)
  isActive       Boolean   @default(true)
  orgId          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime?
  themeMode      ThemeMode @default(LIGHT)

  organization       Organization?      @relation(fields: [orgId], references: [id])
  assignedAudits     Audit[]            @relation("AuditAssignees")
  createdAudits      Audit[]            @relation("AuditCreator")
  findings           Finding[]          @relation("FindingAssignee")
  createdFindings    Finding[]          @relation("FindingCreator")
  actions            CorrectiveAction[] @relation("ActionAssignee")
  createdActions     CorrectiveAction[] @relation("ActionCreator")
  notifications      Notification[]
  activityLogs       ActivityLog[]
  sentInvites        OrgInvite[]        @relation("InviteSender")

  @@unique([email, orgId])
  @@index([orgId])
  @@index([supabaseId])
  @@index([role])
}

// ─── Org Settings ─────────────────────────────────────────────────────────────

model OrgSettings {
  id                   String    @id @default(cuid())
  orgId                String    @unique
  logoUrl              String?
  accentColor          String    @default("#0f172a")
  themeMode            ThemeMode @default(LIGHT)
  displayName          String?
  timezone             String    @default("UTC")
  dateFormat           String    @default("DD/MM/YYYY")
  locale               String    @default("en")
  fiscalYearStartMonth Int       @default(1)
  emailNotifications   Boolean   @default(true)
  deadlineLeadDays     Int       @default(7)
  updatedAt            DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
}

// ─── Org Framework (enabled per org) ─────────────────────────────────────────

model OrgFramework {
  id        String    @id @default(cuid())
  orgId     String
  framework Framework
  enabled   Boolean   @default(false)
  createdAt DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, framework])
  @@index([orgId])
}

// ─── Org Invite ───────────────────────────────────────────────────────────────

model OrgInvite {
  id          String    @id @default(cuid())
  orgId       String
  email       String
  role        UserRole  @default(EMPLOYEE)
  token       String    @unique @default(cuid())
  accepted    Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  sentById    String?

  organization Organization @relation(fields: [orgId], references: [id])
  sentBy       User?         @relation("InviteSender", fields: [sentById], references: [id])

  @@index([orgId])
  @@index([token])
  @@index([email])
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model Audit {
  id          String      @id @default(cuid())
  orgId       String
  title       String
  description String?
  type        AuditType
  status      AuditStatus @default(DRAFT)
  scope       String?
  department  String?
  startDate   DateTime?
  endDate     DateTime?
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  createdBy    User?         @relation("AuditCreator", fields: [createdById], references: [id])
  assignees    User[]        @relation("AuditAssignees")
  findings     Finding[]
  evidence     Evidence[]
  activityLogs ActivityLog[]

  @@index([orgId])
  @@index([status])
  @@index([createdAt])
  @@index([department])
}

// ─── Finding ──────────────────────────────────────────────────────────────────

model Finding {
  id           String          @id @default(cuid())
  orgId        String
  auditId      String
  title        String
  description  String?
  severity     FindingSeverity @default(LOW)
  status       FindingStatus   @default(OPEN)
  department   String?
  assigneeId   String?
  createdById  String?
  dueDate      DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  organization    Organization     @relation(fields: [orgId], references: [id])
  audit           Audit            @relation(fields: [auditId], references: [id])
  assignee        User?            @relation("FindingAssignee", fields: [assigneeId], references: [id])
  createdBy       User?            @relation("FindingCreator", fields: [createdById], references: [id])
  actions         CorrectiveAction[]
  evidence        Evidence[]
  controlMappings ControlMapping[]
  activityLogs    ActivityLog[]

  @@index([orgId])
  @@index([auditId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

// ─── Corrective Action ────────────────────────────────────────────────────────

model CorrectiveAction {
  id           String       @id @default(cuid())
  orgId        String
  findingId    String
  title        String
  description  String?
  status       ActionStatus @default(OPEN)
  progress     Int          @default(0)
  assigneeId   String?
  createdById  String?
  dueDate      DateTime?
  closedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  finding      Finding      @relation(fields: [findingId], references: [id])
  assignee     User?        @relation("ActionAssignee", fields: [assigneeId], references: [id])
  createdBy    User?        @relation("ActionCreator", fields: [createdById], references: [id])
  evidence     Evidence[]
  activityLogs ActivityLog[]

  @@index([orgId])
  @@index([findingId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

// ─── Evidence ─────────────────────────────────────────────────────────────────

model Evidence {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  fileUrl     String
  fileType    String
  fileSizeKb  Int?
  auditId     String?
  findingId   String?
  actionId    String?
  uploadedById String?
  createdAt   DateTime @default(now())

  organization   Organization      @relation(fields: [orgId], references: [id])
  audit          Audit?            @relation(fields: [auditId], references: [id])
  finding        Finding?          @relation(fields: [findingId], references: [id])
  action         CorrectiveAction? @relation(fields: [actionId], references: [id])

  @@index([orgId])
  @@index([auditId])
  @@index([findingId])
  @@index([actionId])
  @@index([createdAt])
}

// ─── Risk ─────────────────────────────────────────────────────────────────────

model Risk {
  id             String         @id @default(cuid())
  orgId          String
  name           String
  description    String?
  likelihood     RiskLikelihood
  impact         RiskImpact
  score          Int
  status         RiskStatus     @default(OPEN)
  mitigationPlan String?
  owner          String?
  reviewDate     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id])
  activityLogs ActivityLog[]

  @@index([orgId])
  @@index([status])
  @@index([score])
  @@index([createdAt])
}

// ─── Compliance Framework & Controls ─────────────────────────────────────────

model Control {
  id          String    @id @default(cuid())
  orgId       String
  framework   Framework
  controlId   String
  title       String
  description String?
  category    String?
  isEnabled   Boolean   @default(true)
  createdAt   DateTime  @default(now())

  organization    Organization     @relation(fields: [orgId], references: [id])
  controlMappings ControlMapping[]

  @@unique([orgId, framework, controlId])
  @@index([orgId])
  @@index([framework])
}

model ControlMapping {
  id        String   @id @default(cuid())
  orgId     String
  controlId String
  findingId String
  notes     String?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  control      Control      @relation(fields: [controlId], references: [id])
  finding      Finding      @relation(fields: [findingId], references: [id])

  @@unique([controlId, findingId])
  @@index([orgId])
  @@index([findingId])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  orgId     String
  userId    String
  type      NotificationType
  title     String
  body      String?
  isRead    Boolean          @default(false)
  linkUrl   String?
  createdAt DateTime         @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  orgId      String
  userId     String?
  action     String
  entity     String
  entityId   String
  meta       Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  organization Organization           @relation(fields: [orgId], references: [id])
  user              User?             @relation(fields: [userId], references: [id])
  audit             Audit?            @relation(fields: [entityId], references: [id], map: "ActivityLog_auditId_fkey")
  finding           Finding?          @relation(fields: [entityId], references: [id], map: "ActivityLog_findingId_fkey")
  correctiveAction  CorrectiveAction? @relation(fields: [entityId], references: [id], map: "ActivityLog_actionId_fkey")
  risk              Risk?             @relation(fields: [entityId], references: [id], map: "ActivityLog_riskId_fkey")

  @@index([orgId])
  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}